# Copy this file to `.env.local` and fill in values from your Supabase project
# (Settings → API). Only variables prefixed with VITE_ are exposed to the browser.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_BUCKET=your_bucket_name

# OpenWeatherMap (free tier): https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_key
